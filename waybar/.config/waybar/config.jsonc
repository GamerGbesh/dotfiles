{
  "position": "top",
  "modules-left": ["hyprland/workspaces", "custom/cpu", "custom/ram", "custom/gpu" ,"custom/temps"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["tray", "network", "pulseaudio", "battery", "clock"],
  "clock": {
    "format": "<span foreground='#f5c2e7'>пЂ—   </span>{:%a %d %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "<span size='13000' foreground='#a6e3a1'>{icon} </span> {capacity}%",
    "format-warning": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {capacity}%",
    "format-critical": "<span size='13000' foreground='#E38C8F'>{icon} </span> {capacity}%",
    "format-charging": "<span size='13000' foreground='#B1E3AD'>п‡¦ </span>{capacity}%",
    "format-plugged": "<span size='13000' foreground='#B1E3AD'>п‡¦ </span>{capacity}%",
    "format-alt": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {time}",
    "format-full": "<span size='13000' foreground='#B1E3AD'>пЂ„ </span>{capacity}%",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
    "tooltip-format": "{time}"
  },
  "network": {
    "format-wifi": "<span size='13000' foreground='#f5e0dc'>п‡«  </span>{essid}",
    "format-ethernet": "<span size='13000' foreground='#f5e0dc'>у°¤­  </span> Disconnected",
    "format-linked": "{ifname} (No IP) пћ–",
    "format-disconnected": "<span size='13000' foreground='#f5e0dc'>пЃЄ  </span>Disconnected",
    "tooltip-format-wifi": "Signal Strenght: {signalStrength}%"
  },
  "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-muted": "п‘¦",
      "format-icons": {
          "default": ["пЂ¦", "пЂ§", "пЂЁ "]
      },
      "on-click": "pavucontrol"
  },
  "tray": {
    "spacing": 10
  },
     
// в”Ђв”Ђ Add these inside your modules{} in ~/.config/waybar/config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Then reference them in your "modules-left/center/right" array, e.g.:
//   "modules-right": ["custom/cpu", "custom/ram", "custom/gpu", "custom/temps", ...]

"custom/cpu": {
    "exec": "~/.local/bin/sysmon-cpu.sh",
    "interval": 2,
    "format": "  {}% cpu",
    "tooltip": false
},

"custom/ram": {
    "exec": "free -m | awk '/^Mem:/{printf \"%.0f%%\", $3/$2*100}'",
    "interval": 2,
    "format": "  {} ram",
    "tooltip": false
},

"custom/gpu": {
    "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | tr -d ' '",
    "interval": 2,
    "format": "у°ў®  {}% gpu",
    "tooltip": false
},

"custom/temps": {
    "exec": "~/.local/bin/sysmon-temps.sh | python3 -c \"import sys,json; d=json.load(sys.stdin); print(f\\\"{d['cpu']}В° cpu | {d['gpu']}В° gpu\\\")\"",
    "interval": 3,
    "format": "  {}",
    "tooltip": false
}
}
